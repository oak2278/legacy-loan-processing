{
  // ---------------------------------------------------------------------------
  // appsettings.json — LoanProcessing.Web (.NET 8.0)
  // Migrated from Web.config <connectionStrings>, <appSettings>, and
  // <system.web> / <system.webServer> sections.
  //
  // Web.config keys and their ASP.NET Core equivalents:
  //
  //   Web.config                          appsettings.json
  //   ------------------------------------  ------------------------------------
  //   connectionStrings/LoanProcessing*   ConnectionStrings/LoanProcessingConnection
  //   appSettings/webpages:Version        (removed - obsolete ASP.NET WebPages key)
  //   appSettings/webpages:Enabled        AppSettings/WebPagesEnabled
  //   appSettings/ClientValidationEnabled AppSettings/ClientValidationEnabled
  //   appSettings/UnobtrusiveJavaScript*  AppSettings/UnobtrusiveJavaScriptEnabled
  //   system.web/compilation debug=true   use ASPNETCORE_ENVIRONMENT=Development
  //   system.web/httpRuntime timeout=120  Kestrel/Limits/KeepAliveTimeout below
  //   system.webServer/security/          Kestrel/Limits/MaxRequestBodySize below
  //     requestLimits maxAllowed=30000000
  //   runtime/assemblyBinding             handled by NuGet in SDK-style projects
  // ---------------------------------------------------------------------------
  "ConnectionStrings": {
    // Development connection string (matches Web.config default).
    // For SQL Server authentication, use:
    //   "Server=YOUR_SERVER;Database=LoanProcessing;User Id=u;Password=p;"
    "LoanProcessingConnection": "Data Source=(localdb)\\MSSQLLocalDB;Initial Catalog=LoanProcessing;Integrated Security=True;Connect Timeout=30;Encrypt=False;TrustServerCertificate=False;ApplicationIntent=ReadWrite;MultiSubnetFailover=False"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",
  // ---------------------------------------------------------------------------
  // Migrated appSettings keys from Web.config
  // ---------------------------------------------------------------------------
  "AppSettings": {
    "WebPagesEnabled": false,
    "ClientValidationEnabled": true,
    "UnobtrusiveJavaScriptEnabled": true
  },
  // ---------------------------------------------------------------------------
  // Kestrel limits — mirrors system.webServer/security/requestLimits
  // (maxAllowedContentLength=30000000) and httpRuntime executionTimeout=120.
  // ---------------------------------------------------------------------------
  "Kestrel": {
    "Limits": {
      "MaxRequestBodySize": 30000000,
      "KeepAliveTimeout": "00:02:00"
    }
  }
}